# Copy this file to .env and fill in your values

# Anthropic API key, used to translate technical findings into plain English.
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# Comma-separated list of origins allowed to call this API (your frontend URL).
ALLOWED_ORIGINS=http://localhost:5173

# Max seconds to wait for a target site to respond before giving up.
SCAN_TIMEOUT_SECONDS=10

# Secret key for signing authentication tokens.
APP_SECRET_KEY=replace-with-a-secure-random-value

# Optional path for the SQLite database file.
DATABASE_PATH=backend/nexus_shield.db

# Resend email service API key for sending security alert emails.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
# Verified sender address for outgoing notifications.
EMAIL_FROM=alerts@example.com
# Public frontend link used in email buttons.
FRONTEND_URL=http://localhost:5173
# Optional AI provider override for explainers.
AI_PROVIDER=anthropic
